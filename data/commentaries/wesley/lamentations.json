      "verse_range_osis": "Lam.1.7",
      "verse_text": null,
      "commentary_text": "Three - It is probable there were more keepers of the door, but the captain of the guard took only three of the chief.",
      "summary": null,
      "summary_review_status": "withheld",
      "cross_references": [],
