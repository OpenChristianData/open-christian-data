{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openchristiandata/open-christian-data/schemas/v1/topical_reference.schema.json",
  "title": "Topical Reference Resource File",
  "description": "A topic-keyed verse index: metadata envelope + array of topic entries with subtopics and scripture references. Covers topical reference works such as Nave's Topical Bible and Torrey's New Topical Textbook.",
  "type": "object",
  "required": ["meta", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id", "title", "author", "original_publication_year",
        "language", "tradition", "license", "schema_type", "schema_version",
        "completeness", "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable resource identifier, kebab-case."
        },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "author_birth_year": { "type": ["integer", "null"] },
        "author_death_year": { "type": ["integer", "null"] },
        "original_publication_year": { "type": ["integer", "null"] },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}$" },
        "tradition": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reformed", "lutheran", "anglican", "baptist", "methodist",
              "catholic", "orthodox", "ecumenical", "non-denominational",
              "puritan", "nonconformist", "patristic", "wesleyan",
              "presbyterian", "particular-baptist", "continental-reformed",
              "arminian", "calvinist", "evangelical", "confessional"
            ]
          },
          "minItems": 1
        },
        "tradition_notes": { "type": ["string", "null"] },
        "license": {
          "type": "string",
          "enum": ["cc0-1.0", "public-domain", "cc-by-4.0", "cc-by-sa-4.0"]
        },
        "schema_type": { "type": "string", "const": "topical_reference" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "completeness": {
          "type": "string",
          "enum": ["full", "partial", "in-progress"]
        },
        "provenance": {
          "type": "object",
          "required": [
            "source_url", "source_format", "source_edition",
            "download_date", "source_hash", "processing_method",
            "processing_script_version", "processing_date"
          ],
          "additionalProperties": false,
          "properties": {
            "source_url": { "type": "string" },
            "source_format": { "type": "string" },
            "source_edition": { "type": "string" },
            "download_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "source_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "processing_method": {
              "type": "string",
              "enum": ["manual", "automated", "automated-with-review", "ocr", "ocr-with-review"]
            },
            "processing_script_version": { "type": "string" },
            "processing_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entry_id", "index_id", "topic", "subtopics"],
        "additionalProperties": false,
        "properties": {
          "entry_id": {
            "type": "string",
            "description": "Stable unique identifier: {index-id}.{topic-slug}"
          },
          "index_id": {
            "type": "string",
            "description": "Kebab-case index identifier, e.g. torreys-topical-textbook."
          },
          "topic": {
            "type": "string",
            "minLength": 1,
            "description": "Primary topic label. SKOS prefLabel."
          },
          "alt_topics": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Alternative topic labels. SKOS altLabel."
          },
          "subtopics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "references"],
              "additionalProperties": false,
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Subtopic heading, e.g. 'Is of God' or 'Exemplified'."
                },
                "references": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["raw", "osis"],
                    "additionalProperties": false,
                    "properties": {
                      "raw": {
                        "type": "string",
                        "description": "Reference as it appears in the source."
                      },
                      "osis": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Normalized OSIS. Empty in initial pipeline pass; populated during enrichment."
                      }
                    }
                  },
                  "description": "Scripture references supporting this subtopic."
                }
              }
            },
            "description": "Labeled groups of verse references within the topic."
          },
          "related_topics": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Cross-referenced topic names. SKOS related."
          }
        }
      }
    }
  }
}
