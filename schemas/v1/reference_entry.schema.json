{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openchristiandata/open-christian-data/schemas/v1/reference_entry.schema.json",
  "title": "Reference Entry Resource File",
  "description": "A structured Bible dictionary or encyclopedia resource: metadata envelope + array of term entries. Covers Easton's, Smith's, and Hitchcock's. NOT Torrey's (see topical_reference.schema.json).",
  "type": "object",
  "required": ["meta", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id", "title", "author", "original_publication_year",
        "language", "tradition", "license", "schema_type", "schema_version",
        "completeness", "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable resource identifier, kebab-case."
        },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "author_birth_year": { "type": ["integer", "null"] },
        "author_death_year": { "type": ["integer", "null"] },
        "original_publication_year": { "type": ["integer", "null"] },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}$" },
        "tradition": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reformed", "lutheran", "anglican", "baptist", "methodist",
              "catholic", "orthodox", "ecumenical", "non-denominational",
              "puritan", "nonconformist", "patristic", "wesleyan",
              "presbyterian", "particular-baptist", "continental-reformed",
              "arminian", "calvinist", "evangelical", "confessional"
            ]
          },
          "minItems": 1
        },
        "tradition_notes": { "type": ["string", "null"] },
        "license": {
          "type": "string",
          "enum": ["cc0-1.0", "public-domain", "cc-by-4.0", "cc-by-sa-4.0"]
        },
        "schema_type": { "type": "string", "const": "reference_entry" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "completeness": {
          "type": "string",
          "enum": ["full", "partial", "in-progress"]
        },
        "provenance": {
          "type": "object",
          "required": [
            "source_url", "source_format", "source_edition",
            "download_date", "source_hash", "processing_method",
            "processing_script_version", "processing_date"
          ],
          "additionalProperties": false,
          "properties": {
            "source_url": { "type": "string" },
            "source_format": { "type": "string" },
            "source_edition": { "type": "string" },
            "download_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "source_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "processing_method": {
              "type": "string",
              "enum": ["manual", "automated", "automated-with-review", "ocr", "ocr-with-review"]
            },
            "processing_script_version": { "type": "string" },
            "processing_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["entry_id", "dictionary_id", "term", "definition_blocks", "word_count"],
        "additionalProperties": false,
        "properties": {
          "entry_id": {
            "type": "string",
            "description": "Stable unique identifier: {dictionary-id}.{term-slug}"
          },
          "dictionary_id": {
            "type": "string",
            "description": "Kebab-case dictionary identifier, e.g. eastons-bible-dictionary."
          },
          "term": {
            "type": "string",
            "minLength": 1,
            "description": "Headword as it appears in the dictionary."
          },
          "alt_terms": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Alternative forms or spellings. SKOS altLabel pattern."
          },
          "definition_blocks": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1,
            "description": "Paragraph array from source. Each element is one block of definition text."
          },
          "scripture_references": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["raw", "osis"],
              "additionalProperties": false,
              "properties": {
                "raw": {
                  "type": "string",
                  "description": "Reference as it appears in the source."
                },
                "osis": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Normalized OSIS. May be empty if unparseable."
                }
              }
            },
            "description": "Extracted scripture references. Empty in initial pipeline pass; populated during enrichment."
          },
          "related_terms": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Cross-referenced terms within the same dictionary. SKOS related pattern."
          },
          "word_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Total word count across all definition_blocks."
          }
        }
      }
    }
  }
}
