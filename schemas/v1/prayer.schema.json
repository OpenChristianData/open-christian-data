{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openchristiandata/open-christian-data/schemas/v1/prayer.schema.json",
  "title": "Prayer Collection File",
  "description": "A structured prayer collection: metadata envelope + array of individual prayer records.",
  "type": "object",
  "required": ["meta", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id", "title", "language", "tradition", "license",
        "schema_type", "schema_version", "completeness", "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable resource identifier, kebab-case." },
        "title": { "type": "string" },
        "author": { "type": ["string", "null"] },
        "author_birth_year": { "type": ["integer", "null"] },
        "author_death_year": { "type": ["integer", "null"] },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "original_publication_year": { "type": ["integer", "null"] },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}$" },
        "original_language": { "type": ["string", "null"], "pattern": "^[a-z]{2,3}$" },
        "tradition": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reformed", "lutheran", "anglican", "baptist", "methodist",
              "catholic", "orthodox", "ecumenical", "non-denominational",
              "puritan", "nonconformist", "patristic", "wesleyan",
              "presbyterian", "particular-baptist", "continental-reformed",
              "arminian", "calvinist", "evangelical", "confessional"
            ]
          },
          "minItems": 1
        },
        "tradition_notes": { "type": ["string", "null"] },
        "era": {
          "type": ["string", "null"],
          "enum": ["apostolic", "patristic", "medieval", "reformation", "post-reformation", "modern", null]
        },
        "audience": {
          "type": ["string", "null"],
          "enum": ["scholarly", "pastoral", "lay", "children", null]
        },
        "license": {
          "type": "string",
          "enum": ["cc0-1.0", "cc-by-4.0", "cc-by-sa-4.0", "public-domain"]
        },
        "schema_type": { "type": "string", "const": "prayer" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "completeness": {
          "type": "string",
          "enum": ["full", "partial", "in-progress"]
        },
        "provenance": {
          "type": "object",
          "required": [
            "source_url", "source_format", "source_edition",
            "download_date", "source_hash", "processing_method",
            "processing_script_version", "processing_date"
          ],
          "additionalProperties": false,
          "properties": {
            "source_url": { "type": "string" },
            "source_format": { "type": "string" },
            "source_edition": { "type": "string" },
            "download_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "source_hash": {
              "type": "string",
              "description": "SHA-256 of the combined raw source bytes, or of the primary source file.",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "processing_method": {
              "type": "string",
              "enum": ["manual", "automated", "automated-with-review", "ocr", "ocr-with-review"]
            },
            "processing_script_version": { "type": "string" },
            "processing_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "collection_id", "prayer_id", "content_blocks", "word_count"
        ],
        "additionalProperties": false,
        "properties": {
          "collection_id": {
            "type": "string",
            "description": "Kebab-case collection identifier."
          },
          "prayer_id": {
            "type": "string",
            "description": "Unique identifier within the collection, kebab-case."
          },
          "title": {
            "type": ["string", "null"],
            "description": "Formal title if one exists, e.g. 'The First Sunday of Advent'."
          },
          "incipit": {
            "type": ["string", "null"],
            "description": "Opening words -- used as identifier when no formal title exists."
          },
          "author": {
            "type": ["string", "null"],
            "description": "Named author, if known."
          },
          "year": {
            "type": ["integer", "null"],
            "description": "Year of composition, if known."
          },
          "occasion": {
            "type": ["string", "null"],
            "description": "Liturgical or devotional occasion, e.g. Morning Prayer, Eucharist, Advent."
          },
          "content_blocks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "Prose paragraphs or sections. One string per natural paragraph or section."
          },
          "scripture_references": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["raw", "osis"],
              "additionalProperties": false,
              "properties": {
                "raw": { "type": "string", "description": "Reference as printed in the source." },
                "osis": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Normalized OSIS references. May be empty if unparseable."
                }
              }
            }
          },
          "context": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": ["work", "location"],
                "additionalProperties": false,
                "properties": {
                  "work": { "type": "string", "description": "The larger work this prayer comes from." },
                  "location": { "type": "string", "description": "Location within the work, e.g. Chapter IX.2." }
                }
              }
            ]
          },
          "word_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
