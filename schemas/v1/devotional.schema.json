{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openchristiandata/open-christian-data/schemas/v1/devotional.schema.json",
  "title": "Devotional Resource File",
  "description": "A structured devotional resource: metadata envelope + array of date-keyed devotional entries.",
  "type": "object",
  "required": ["meta", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id", "title", "author", "language", "tradition", "license",
        "schema_type", "schema_version", "completeness", "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable resource identifier, kebab-case." },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "author_birth_year": { "type": ["integer", "null"] },
        "author_death_year": { "type": ["integer", "null"] },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "original_publication_year": { "type": ["integer", "null"] },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}$" },
        "original_language": { "type": ["string", "null"], "pattern": "^[a-z]{2,3}$" },
        "tradition": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reformed", "lutheran", "anglican", "baptist", "methodist",
              "catholic", "orthodox", "ecumenical", "non-denominational",
              "puritan", "nonconformist", "patristic", "wesleyan",
              "presbyterian", "particular-baptist", "continental-reformed",
              "arminian", "calvinist", "evangelical", "confessional"
            ]
          },
          "minItems": 1
        },
        "tradition_notes": { "type": ["string", "null"] },
        "era": {
          "type": ["string", "null"],
          "enum": ["apostolic", "patristic", "medieval", "reformation", "post-reformation", "modern", null]
        },
        "audience": {
          "type": ["string", "null"],
          "enum": ["scholarly", "pastoral", "lay", "children", null]
        },
        "license": {
          "type": "string",
          "enum": ["cc0-1.0", "cc-by-4.0", "cc-by-sa-4.0", "public-domain"]
        },
        "schema_type": { "type": "string", "const": "devotional" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "completeness": {
          "type": "string",
          "enum": ["full", "partial", "in-progress"]
        },
        "provenance": {
          "type": "object",
          "required": [
            "source_url", "source_format", "source_edition",
            "download_date", "source_hash", "processing_method",
            "processing_script_version", "processing_date"
          ],
          "additionalProperties": false,
          "properties": {
            "source_url": { "type": "string" },
            "source_format": { "type": "string" },
            "source_edition": { "type": "string" },
            "download_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "source_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "processing_method": {
              "type": "string",
              "enum": ["manual", "automated", "automated-with-review", "ocr", "ocr-with-review"]
            },
            "processing_script_version": { "type": "string" },
            "processing_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "collection_id", "entry_id", "month", "day", "title",
          "content_blocks", "word_count"
        ],
        "additionalProperties": false,
        "properties": {
          "collection_id": {
            "type": "string",
            "description": "Kebab-case collection identifier."
          },
          "entry_id": {
            "type": "string",
            "pattern": "^\\d{2}-\\d{2}(-\\w+)?$",
            "description": "MM-DD or MM-DD-period, e.g. 01-01-morning, 12-31-evening."
          },
          "month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31
          },
          "period": {
            "type": ["string", "null"],
            "enum": ["morning", "evening", null],
            "description": "morning, evening, or null for single-reading collections."
          },
          "title": {
            "type": "string",
            "description": "Display title, e.g. January 1 -- Morning."
          },
          "primary_reference": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": ["raw", "osis"],
                "additionalProperties": false,
                "properties": {
                  "raw": { "type": "string", "description": "Reference as printed in the source." },
                  "osis": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Normalized OSIS references. May be empty if unparseable."
                  }
                }
              }
            ]
          },
          "primary_reference_text": {
            "type": ["string", "null"],
            "description": "BSB verse text (enrichment step -- null at source layer)."
          },
          "content_blocks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "Devotional text split by paragraph."
          },
          "word_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
