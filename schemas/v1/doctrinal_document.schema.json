{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openchristiandata/open-christian-data/schemas/v1/doctrinal_document.schema.json",
  "title": "Doctrinal Document Resource File",
  "description": "A structured doctrinal document: metadata envelope + single hierarchical document with recursive units tree. Handles confessions (WCF, LBC 1689), canons (Dort), creeds (Apostles', Nicene), and declarations.",
  "type": "object",
  "required": ["meta", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id", "title", "author", "original_publication_year",
        "language", "tradition", "license", "schema_type",
        "schema_version", "completeness", "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable resource identifier, kebab-case." },
        "title": { "type": "string" },
        "author": { "type": ["string", "null"], "description": "Primary author or authoring body (e.g. 'Westminster Assembly')." },
        "author_birth_year": { "type": ["integer", "null"] },
        "author_death_year": { "type": ["integer", "null"] },
        "contributors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "original_publication_year": { "type": ["integer", "null"] },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}$" },
        "tradition": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reformed", "lutheran", "anglican", "baptist", "methodist",
              "catholic", "orthodox", "ecumenical", "non-denominational",
              "puritan", "nonconformist", "patristic", "wesleyan",
              "presbyterian", "particular-baptist", "continental-reformed"
            ]
          },
          "minItems": 0
        },
        "tradition_notes": { "type": ["string", "null"] },
        "license": {
          "type": "string",
          "enum": ["cc0-1.0", "cc-by-4.0", "cc-by-sa-4.0", "public-domain"]
        },
        "schema_type": { "type": "string", "const": "doctrinal_document" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "completeness": {
          "type": "string",
          "enum": ["full", "partial", "in-progress"]
        },
        "provenance": {
          "type": "object",
          "required": [
            "source_url", "source_format", "source_edition",
            "download_date", "source_hash", "processing_method",
            "processing_script_version", "processing_date"
          ],
          "additionalProperties": false,
          "properties": {
            "source_url": { "type": "string" },
            "source_format": { "type": "string" },
            "source_edition": { "type": "string" },
            "download_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "source_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "processing_method": {
              "type": "string",
              "enum": ["manual", "automated", "automated-with-review", "ocr", "ocr-with-review"]
            },
            "processing_script_version": { "type": "string" },
            "processing_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "data": {
      "type": "object",
      "required": ["document_id", "document_kind", "units"],
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string",
          "description": "Kebab-case identifier, e.g. 'westminster-confession-of-faith'."
        },
        "document_kind": {
          "type": "string",
          "enum": ["confession", "canon", "creed", "declaration"],
          "description": "High-level document category."
        },
        "revision_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["year", "description"],
            "properties": {
              "year": { "type": "integer" },
              "body": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "units": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/unit" }
        }
      }
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "required": ["raw", "osis"],
      "additionalProperties": false,
      "properties": {
        "raw": { "type": "string", "description": "Reference as it appears in the source." },
        "osis": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Normalized OSIS references. May be empty if unparseable."
        }
      }
    },
    "proof": {
      "type": "object",
      "required": ["id", "references"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "description": "Proof number matching [N] markers in content_with_proofs." },
        "references": {
          "type": "array",
          "items": { "$ref": "#/$defs/reference" }
        }
      }
    },
    "unit": {
      "type": "object",
      "required": ["unit_type"],
      "additionalProperties": false,
      "properties": {
        "unit_type": {
          "type": "string",
          "enum": ["chapter", "section", "article", "text", "canon", "rejection"],
          "description": "Structural type of this node in the document hierarchy."
        },
        "number": {
          "type": "string",
          "description": "Unit identifier. String to support Roman numerals and alphanumeric IDs."
        },
        "title": { "type": "string" },
        "content": {
          "type": "string",
          "description": "Plain text content (canonical). Present on leaf nodes."
        },
        "content_with_proofs": {
          "type": "string",
          "description": "Content text with [N] proof markers preserved."
        },
        "proofs": {
          "type": "array",
          "items": { "$ref": "#/$defs/proof" }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/unit" },
          "description": "Nested units (recursive). Present on non-leaf nodes."
        }
      }
    }
  }
}
