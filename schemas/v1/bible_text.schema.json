{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openchristiandata/open-christian-data/schemas/v1/bible_text.schema.json",
  "title": "Bible Text Resource File",
  "description": "A verse-level Bible text resource: metadata envelope + array of verse records. One file per book.",
  "type": "object",
  "required": ["meta", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id", "title", "language", "license",
        "schema_type", "schema_version", "completeness",
        "provenance", "scope"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Stable resource identifier, kebab-case." },
        "title": { "type": "string" },
        "language": { "type": "string", "pattern": "^[a-z]{2,3}$" },
        "original_language": { "type": ["string", "null"], "pattern": "^[a-z]{2,3}$" },
        "tradition": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reformed", "lutheran", "anglican", "baptist", "methodist",
              "catholic", "orthodox", "ecumenical", "non-denominational",
              "puritan", "nonconformist", "patristic", "wesleyan",
              "presbyterian", "particular-baptist", "continental-reformed",
              "arminian", "calvinist", "evangelical", "confessional"
            ]
          },
          "minItems": 1
        },
        "tradition_notes": { "type": ["string", "null"] },
        "license": {
          "type": "string",
          "enum": ["cc0-1.0", "cc-by-4.0", "cc-by-sa-4.0", "public-domain"]
        },
        "schema_type": { "type": "string", "const": "bible_text" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "completeness": {
          "type": "string",
          "enum": ["full", "partial", "in-progress"]
        },
        "provenance": {
          "type": "object",
          "required": [
            "source_url", "source_format", "source_edition",
            "download_date", "source_hash", "processing_method",
            "processing_script_version", "processing_date"
          ],
          "additionalProperties": false,
          "properties": {
            "source_url": { "type": "string" },
            "source_format": { "type": "string" },
            "source_edition": { "type": "string" },
            "download_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "source_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "processing_method": {
              "type": "string",
              "enum": ["manual", "automated", "automated-with-review", "ocr", "ocr-with-review"]
            },
            "processing_script_version": { "type": "string" },
            "processing_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "notes": { "type": ["string", "null"] }
          }
        },
        "scope": {
          "type": "object",
          "description": "Book identity for this file. All records in data[] belong to this book.",
          "required": ["book", "book_osis", "book_number"],
          "additionalProperties": false,
          "properties": {
            "book": { "type": "string", "description": "Full canonical English book name." },
            "book_osis": { "type": "string", "description": "OSIS book code, e.g. Gen, Ps, Rev." },
            "book_number": {
              "type": "integer",
              "minimum": 1,
              "maximum": 66,
              "description": "Canonical Bible book order (1=Genesis, 66=Revelation)."
            }
          }
        }
      }
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["osis", "chapter", "verse", "text"],
        "additionalProperties": false,
        "properties": {
          "osis": {
            "type": "string",
            "description": "OSIS verse reference, e.g. Gen.1.1",
            "pattern": "^[0-9]?[A-Z][a-zA-Z0-9]+\\.\\d+\\.\\d+$"
          },
          "chapter": { "type": "integer", "minimum": 1 },
          "verse": { "type": "integer", "minimum": 1 },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "Verse text, whitespace-trimmed."
          },
          "word_count": { "type": "integer", "minimum": 0 },
          "token_count": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
