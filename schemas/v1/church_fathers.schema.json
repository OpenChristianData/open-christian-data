{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openchristiandata/open-christian-data/schemas/v1/church_fathers.schema.json",
  "title": "Church Fathers Quote File",
  "description": "A structured Church Fathers quote resource: metadata envelope + array of verse-keyed quote entries. One file per author, sourced from HistoricalChristianFaith/Commentaries-Database.",
  "type": "object",
  "required": ["meta", "data"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id", "author", "license", "schema_type", "schema_version", "provenance"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable resource identifier, kebab-case. Derived from author directory name."
        },
        "author": { "type": "string" },
        "author_birth_year": { "type": ["integer", "null"] },
        "author_death_year": { "type": ["integer", "null"] },
        "tradition": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "reformed", "lutheran", "anglican", "baptist", "methodist",
              "catholic", "orthodox", "ecumenical", "non-denominational",
              "puritan", "nonconformist", "patristic", "wesleyan",
              "presbyterian", "particular-baptist", "continental-reformed",
              "arminian", "calvinist", "evangelical", "confessional"
            ]
          }
        },
        "tradition_notes": { "type": ["string", "null"] },
        "license": {
          "type": "string",
          "enum": ["cc0-1.0", "public-domain", "cc-by-4.0", "cc-by-sa-4.0"]
        },
        "schema_type": { "type": "string", "const": "church_fathers" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "provenance": {
          "type": "object",
          "required": [
            "source_url", "source_format", "source_edition",
            "download_date", "source_hash", "processing_method",
            "processing_script_version", "processing_date"
          ],
          "additionalProperties": false,
          "properties": {
            "source_url": { "type": "string" },
            "source_format": { "type": "string" },
            "source_edition": { "type": "string" },
            "download_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "source_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "processing_method": {
              "type": "string",
              "enum": ["manual", "automated", "automated-with-review", "ocr", "ocr-with-review"]
            },
            "processing_script_version": { "type": "string" },
            "processing_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "notes": { "type": ["string", "null"] }
          }
        }
      }
    },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "entry_id", "author", "anchor_ref", "quote", "source_title",
          "source_url", "word_count"
        ],
        "additionalProperties": false,
        "properties": {
          "entry_id": {
            "type": "string",
            "description": "Stable unique identifier: {author-slug}.{osis-ref}.{source-slug}"
          },
          "author": { "type": "string" },
          "anchor_ref": {
            "type": "object",
            "required": ["raw", "osis"],
            "additionalProperties": false,
            "properties": {
              "raw": {
                "type": "string",
                "description": "Reference as it appears in the source (reconstructed from filename)."
              },
              "osis": {
                "type": "array",
                "items": { "type": "string" },
                "description": "OSIS refs. May be empty if book name is not in the canonical 66-book mapping."
              }
            }
          },
          "quote": {
            "type": "string",
            "minLength": 1,
            "description": "Full quote text from the author."
          },
          "source_title": {
            "type": "string",
            "description": "Title of the source work, e.g. 'Homily on 1 Corinthians 23'."
          },
          "source_url": {
            "type": "string",
            "description": "URL to the source on historicalchristian.faith or similar. May be empty."
          },
          "attribution_note": {
            "type": ["string", "null"],
            "description": "Additional attribution context (from append_to_author_name in source). For book-as-author entries like '1 Corinthians', this holds the specific verse reference."
          },
          "context": {
            "type": ["string", "null"],
            "description": "Optional section context from the source, e.g. 'Section 97. On the faith of Abraham.'"
          },
          "word_count": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
